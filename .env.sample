# email-mcp Configuration
# All environment variables use the EMAIL_MCP_ prefix

# IMAP settings (for mbsync sync)
# EMAIL_MCP_IMAP_HOST=127.0.0.1
# EMAIL_MCP_IMAP_PORT=1143
# EMAIL_MCP_IMAP_USERNAME=user@example.com
# EMAIL_MCP_IMAP_PASSWORD=your-bridge-password
# EMAIL_MCP_IMAP_STARTTLS=true

# SMTP settings (for sending)
# EMAIL_MCP_SMTP_HOST=127.0.0.1
# EMAIL_MCP_SMTP_PORT=1025
# EMAIL_MCP_SMTP_USERNAME=user@example.com
# EMAIL_MCP_SMTP_PASSWORD=your-bridge-password
# EMAIL_MCP_SMTP_STARTTLS=false
# EMAIL_MCP_SMTP_CERT_PATH=~/Library/Application Support/protonmail/bridge/cert.pem

# Identity
# EMAIL_MCP_FROM_NAME=Your Name
# EMAIL_MCP_FROM_ADDRESS=user@example.com

# Maildir root (where mbsync syncs to)
# EMAIL_MCP_MAILDIR_ROOT=~/Mail/protonmail

# IMAP cert (for STARTTLS with self-signed certs, e.g. ProtonMail Bridge)
# EMAIL_MCP_IMAP_CERT_PATH=~/Library/Application Support/protonmail/bridge/cert.pem

# Sync settings
# EMAIL_MCP_SYNC_INTERVAL_SECONDS=60
# EMAIL_MCP_SYNC_ON_STARTUP=true
# EMAIL_MCP_MBSYNC_BIN=mbsync
# EMAIL_MCP_MBSYNC_CHANNEL=protonmail

# INBOX sync (periodic mbsync channel:INBOX, 0.3s per cycle)
# EMAIL_MCP_INBOX_SYNC_INTERVAL=60

# Nightly full sync (all folders)
# EMAIL_MCP_NIGHTLY_SYNC_HOUR=3
# EMAIL_MCP_NIGHTLY_SYNC_ENABLED=true

# IMAP IDLE (real-time INBOX notifications)
# EMAIL_MCP_IDLE_ENABLED=true

# Debounced notmuch reindex after mutations
# EMAIL_MCP_REINDEX_DEBOUNCE=60

# Search
# EMAIL_MCP_NOTMUCH_BIN=notmuch

# Server
# EMAIL_MCP_TRANSPORT=stdio
# EMAIL_MCP_HOST=0.0.0.0
# EMAIL_MCP_PORT=8025
# EMAIL_MCP_LOG_LEVEL=INFO

# Auth (optional, for HTTP transport)
# EMAIL_MCP_GITHUB_CLIENT_ID=
# EMAIL_MCP_GITHUB_CLIENT_SECRET=
# EMAIL_MCP_OAUTH_BASE_URL=
# EMAIL_MCP_OAUTH_ALLOWED_USERS=
