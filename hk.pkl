amends "package://github.com/jdx/hk/releases/download/v1.24.0/hk@1.24.0#/Config.pkl"

local linters = new Mapping<String, Step> {
    ["ruff"] {
        glob = List("*.py", "*.pyi")
        check = "uv run ruff check --force-exclude {{files}}"
        fix = "uv run ruff check --fix --force-exclude {{files}}"
    }
    ["ruff_format"] {
        glob = List("*.py", "*.pyi")
        check = "uv run ruff format --check --force-exclude {{files}}"
        fix = "uv run ruff format --force-exclude {{files}}"
    }
    ["ty"] {
        glob = List("*.py", "*.pyi")
        check = "uvx ty check"
    }
}

hooks {
    ["pre-commit"] {
        fix = true
        stash = "git"
        steps {
            ...linters
        }
    }
    ["pre-push"] {
        steps {
            ...linters
            ["pytest"] {
                check = "uv run pytest -q --timeout=30 --ignore=tests/live"
            }
        }
    }
    ["fix"] {
        fix = true
        steps = linters
    }
    ["check"] {
        steps {
            ...linters
            ["pytest"] {
                check = "uv run pytest -q --timeout=30 --ignore=tests/live"
            }
        }
    }
}
